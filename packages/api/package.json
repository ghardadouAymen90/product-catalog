{
  "name": "product-catalog-api",
  "version": "1.0.0",
  "description": "NestJS API for Product Catalog",
  "author": "Ghardadou Aymen",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "debug": "nest start --debug --watch",
    "prod": "node dist/main",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "bash -c 'npx typeorm-ts-node-commonjs migration:generate src/database/migrations/$1 -d src/database/data-source.ts' --",
    "migration:run": "npm run typeorm -- migration:run -d src/database/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/database/data-source.ts",
    "db:reset": "npm run migration:revert && npm run migration:run",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "10.4.1",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.4.1",
    "@nestjs/platform-express": "10.4.1",
    "@nestjs/swagger": "7.4.0",
    "@nestjs/typeorm": "10.0.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "pg": "8.12.0",
    "reflect-metadata": "0.1.14",
    "rxjs": "7.8.2",
    "swagger-ui-express": "4.6.3",
    "typeorm": "0.3.21"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.1",
    "@nestjs/schematics": "10.2.1",
    "@types/node": "22.5.4",
    "@typescript-eslint/eslint-plugin": "8.4.0",
    "@typescript-eslint/parser": "8.4.0",
    "eslint": "9.10.0",
    "prettier": "3.3.3",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.6.2"
  }
}
